# ARKANIS V3.1 — Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Runtime Mode ---
# "local" = Ollama (no API key needed)
# "api"   = Cloud provider (API key required)
ARKANIS_MODE=local

# --- Local LLM (Ollama) ---
ARKANIS_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Cloud API Keys (optional, only needed in api mode) ---
OPENROUTER_API_KEY=
ARKANIS_TIMEOUT=30

# --- Setup State ---
SETUP_COMPLETE=false

# --- Optional Integrations ---
TELEGRAM_BOT_TOKEN=
